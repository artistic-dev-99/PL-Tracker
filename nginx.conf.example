# Nginx Reverse Proxy Configuration for PL Tracker 2 (HTTPS + Custom Domain)
# Save this file as /etc/nginx/sites-available/pltracker on your server

server {
    listen 80;
    server_name pltracker.com www.pltracker.com pltracker.local;

    # Redirect all HTTP traffic to HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name pltracker.com www.pltracker.com pltracker.local;

    # SSL Certificate Paths (Let's Encrypt or Local Certificate)
    ssl_certificate /etc/letsencrypt/live/pltracker.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/pltracker.com/privkey.pem;

    # Modern SSL Security Settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Static File Caching
    location /static/ {
        alias /var/www/pltracker/client/static/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    # Proxy API and Web Requests to Flask Server (Running on Port 5000)
    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Enable WebSocket / Polling Support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
